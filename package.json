{
  "name": "oodim-game",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "oodim Game — a portfolio of web/mobile games (Pac-Man, Galaga, and the true-3D Doom) built autonomously by the oodim AIDLC loop.",
  "scripts": {
    "dev:pacman": "vite --config pacman/vite.config.ts",
    "build:pacman": "tsc --noEmit -p pacman/tsconfig.json && vite build --config pacman/vite.config.ts",
    "preview:pacman": "vite preview --config pacman/vite.config.ts",
    "typecheck:pacman": "tsc --noEmit -p pacman/tsconfig.json",
    "test:e2e:pacman": "playwright test --config pacman/playwright.config.ts",
    "dev:galaga": "vite --config galaga/vite.config.ts",
    "build:galaga": "tsc --noEmit -p galaga/tsconfig.json && vite build --config galaga/vite.config.ts",
    "preview:galaga": "vite preview --config galaga/vite.config.ts",
    "typecheck:galaga": "tsc --noEmit -p galaga/tsconfig.json",
    "test:e2e:galaga": "playwright test --config galaga/playwright.config.ts",
    "dev:doom": "vite --config doom/vite.config.ts",
    "build:doom": "tsc --noEmit -p doom/tsconfig.json && vite build --config doom/vite.config.ts",
    "preview:doom": "vite preview --config doom/vite.config.ts",
    "typecheck:doom": "tsc --noEmit -p doom/tsconfig.json",
    "test:e2e:doom": "playwright test --config doom/playwright.config.ts",
    "dev:agar": "vite --config agar/vite.config.ts",
    "build:agar": "tsc --noEmit -p agar/tsconfig.json && vite build --config agar/vite.config.ts",
    "preview:agar": "vite preview --config agar/vite.config.ts",
    "typecheck:agar": "tsc --noEmit -p agar/tsconfig.json",
    "test:e2e:agar": "playwright test --config agar/playwright.config.ts",
    "test:e2e:agar:broken": "playwright test --config agar/playwright.broken.config.ts",
    "test:e2e:agar:persistence": "playwright test --config agar/playwright.config.ts e2e/persistence-harness.spec.ts",
    "test:e2e:agar:persistence:broken-non-monotone": "playwright test --config agar/playwright.broken-non-monotone-persist.config.ts -g monotonic-persist",
    "test:e2e:agar:persistence:broken-lossy": "playwright test --config agar/playwright.broken-lossy-persist.config.ts -g eviction-roundtrip",
    "dev:agar-server": "wrangler dev --config agar/wrangler.toml",
    "dev:agar-server:broken": "wrangler dev --config agar/wrangler.toml --var AGAR_DO_BREAK_MODE:drop-every-7th",
    "dev:agar-server:broken-non-monotone-persist": "wrangler dev --config agar/wrangler.toml --var AGAR_DO_BREAK_MODE:non-monotone-persist",
    "dev:agar-server:broken-lossy-persist": "wrangler dev --config agar/wrangler.toml --var AGAR_DO_BREAK_MODE:lossy-persist",
    "typecheck:agar-server": "tsc --noEmit -p agar/server/tsconfig.json",
    "dev:aftersign": "vite --config aftersign/vite.config.ts",
    "build:aftersign": "tsc --noEmit -p aftersign/tsconfig.json && vite build --config aftersign/vite.config.ts",
    "preview:aftersign": "vite preview --config aftersign/vite.config.ts",
    "typecheck:aftersign": "tsc --noEmit -p aftersign/tsconfig.json",
    "test:e2e:aftersign": "playwright test --config aftersign/playwright.config.ts",
    "test:e2e:aftersign:durable-save": "playwright test --config aftersign/playwright.config.ts e2e/save-load-durable-contract.spec.ts e2e/durable-save-load.spec.ts",
    "test:e2e:aftersign:durable-save:broken-local-only": "FLAGSHIP_BREAK_MODE=local-only-save playwright test --config aftersign/playwright.broken-local-only-save.config.ts e2e/save-load-durable-contract.spec.ts",
    "test:e2e:aftersign:npc-memory": "playwright test --config aftersign/playwright.config.ts e2e/npc-memory-roundtrip.spec.ts",
    "test:e2e:landing": "playwright test --config landing/playwright.config.ts",
    "build": "npm run build:pacman && npm run build:galaga && npm run build:doom && npm run build:agar && npm run build:aftersign",
    "typecheck": "npm run typecheck:pacman && npm run typecheck:galaga && npm run typecheck:doom && npm run typecheck:agar && npm run typecheck:agar-server && npm run typecheck:aftersign",
    "test:e2e": "npm run test:e2e:pacman && npm run test:e2e:galaga && npm run test:e2e:doom && npm run test:e2e:agar && npm run test:e2e:aftersign && npm run test:e2e:landing",
    "test:harness": "playwright test --config e2e-shared/multiplayer/playwright.harness.config.ts",
    "test:smoke": "playwright test --config e2e-shared/prod-smoke/playwright.config.ts"
  },
  "dependencies": {
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260721.1",
    "@playwright/test": "^1.48.0",
    "@types/three": "^0.184.0",
    "typescript": "^7.0.2",
    "vite": "^8.1.5",
    "wrangler": "^4.112.0"
  }
}
