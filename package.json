{
  "name": "oodim-game",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "oodim Game — a portfolio of web/mobile canvas games (Pac-Man, Galaga) built autonomously by the oodim AIDLC loop.",
  "scripts": {
    "dev:pacman": "vite --config pacman/vite.config.ts",
    "build:pacman": "tsc --noEmit -p pacman/tsconfig.json && vite build --config pacman/vite.config.ts",
    "preview:pacman": "vite preview --config pacman/vite.config.ts",
    "typecheck:pacman": "tsc --noEmit -p pacman/tsconfig.json",
    "test:e2e:pacman": "playwright test --config pacman/playwright.config.ts",
    "dev:galaga": "vite --config galaga/vite.config.ts",
    "build:galaga": "tsc --noEmit -p galaga/tsconfig.json && vite build --config galaga/vite.config.ts",
    "preview:galaga": "vite preview --config galaga/vite.config.ts",
    "typecheck:galaga": "tsc --noEmit -p galaga/tsconfig.json",
    "test:e2e:galaga": "playwright test --config galaga/playwright.config.ts",
    "dev:landing": "vite --config landing/vite.config.ts",
    "build:landing": "tsc --noEmit -p landing/tsconfig.json && vite build --config landing/vite.config.ts",
    "preview:landing": "vite preview --config landing/vite.config.ts",
    "typecheck:landing": "tsc --noEmit -p landing/tsconfig.json",
    "build": "npm run build:landing && npm run build:pacman && npm run build:galaga",
    "typecheck": "npm run typecheck:landing && npm run typecheck:pacman && npm run typecheck:galaga",
    "test:e2e": "npm run test:e2e:pacman && npm run test:e2e:galaga"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
